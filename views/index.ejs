<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <link rel="stylesheet" href="style.css">
  <title>Kurser - DT207G 1</title>
</head>

<body>
  <div id="app">

    <h1>Mina kurser</h1>

    <div id="course-list">

      <% if (courses.length === 0) { %>
        <p>Inga kurser sparade ännu.</p>
      <% } %>

      <% courses.forEach(course => { %>
        <div class="course-card">

          <h3>
            <%= course.coursename %> (<%= course.coursecode %>)
          </h3>

          <p>Progression: <%= course.progression %></p>

          <div class="actions">
            <a href="<%= course.syllabus %>" target="_blank">
              <button>Kursplan</button>
            </a>

            <a href="/delete/<%= course.id %>">
              <button class="delete">Radera</button>
            </a>
          </div>

        </div>
      <% }) %>

    </div>

    <a href="/ny"><button>Lägg till kurs</button></a>

  </div>
</body>
</html>